# ── Polymath Platform — Environment Variables ────────────────────────────────
# Copy this file to .env.local and fill in your keys.
# None are required for the basic demo — all gracefully degrade.

# ── Liquid AI (required for live SAR image analysis) ─────────────────────────
# Get a free key from: https://labs.liquid.ai
LIQUID_API_KEY=

# ── AIS Vessel Tracking (required for live ship positions on map) ─────────────
# Free API key from: https://aisstream.io/authenticate
# Used by useAISStream hook → AISLayer map component
NEXT_PUBLIC_AISSTREAM_API_KEY=

# ── Copernicus Data Space (required for Sentinel-1 scene DOWNLOAD) ────────────
# Catalog search (SentinelPanel) is free without auth.
# Register free at: https://dataspace.copernicus.eu/
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=

# ── Python SAR Processor (optional — Phase 2) ─────────────────────────────────
# URL of the deployed FastAPI service (Railway / Render / self-hosted)
# Handles heavy PyGMTSAR InSAR processing for live displacement time series
SENTINEL_PROCESSOR_URL=

# ── Vercel Analytics (auto-injected by Vercel, no action needed) ──────────────
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
