{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/risk-grid",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=86400" }
      ]
    },
    {
      "source": "/api/alerts",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=3600" }
      ]
    }
  ]
}
